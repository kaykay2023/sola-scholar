# Copy to .env for local dev; set the same vars in Railway for production.
# DO NOT commit .env (it is gitignored).

# ── Internal auth (V1: HTTP Basic). Required to start the server safely. ──
# Pick a strong password. Clerk-based auth is the V2 plan.
INTERNAL_USER=sola
INTERNAL_PASSWORD=

# ── Storage ──
# Directory that data.json lives in (Railway: mount a Volume here).
DATA_PATH=./data

# ── External APIs (server-side only — never sent to the browser) ──
APOLLO_API_KEY=
PDL_API_KEY=
FIRECRAWL_API_KEY=
GITHUB_TOKEN=
HUNTER_API_KEY=
ADZUNA_APP_ID=
ADZUNA_API_KEY=
OPENAI_API_KEY=

# ── Airtable mirror (optional) ──
AIRTABLE_PAT=
AIRTABLE_BASE_ID=
AIRTABLE_TABLE_NAME=Matches

# ── Clerk (V2 — listed for forward compatibility, not used in V1) ──
CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# Port (Railway sets this automatically)
PORT=3000
